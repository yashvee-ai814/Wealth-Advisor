# ========================
#  FastAPI .gitignore
# ========================

# ========================
#  Virtual Environment
# ========================
venv/
.venv/
env/
ENV/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# Environment variables
.env
.env.local
.env.production

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# MyPy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Logs
*.log
logs/

# Database files
*.db
*.sqlite3

# Alembic (migrations) — keep versions/, ignore auto-generated envs
# alembic/versions/  ← intentionally NOT ignored

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/
*.ipynb
